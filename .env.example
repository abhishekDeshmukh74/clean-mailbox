# --- Backend (apps/api) ---
# Google OAuth client (from Google Cloud Console → Credentials → OAuth Client ID, Web)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Signed cookie session secret — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=change-me-to-a-long-random-string

# Frontend URL allowed for CORS + post-login redirect target
FRONTEND_URL=http://localhost:5173

# Where tokens + cached emails are stored
CACHE_DIR=./cache

# LLM via LiteLLM → Ollama
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=ollama/gemma3

# Server-side clamp on how many emails the UI may request per call
MAX_FETCH_LIMIT=500

# --- Frontend (apps/web) ---
VITE_API_URL=http://localhost:8000
